# Copy to .env before running.
# Never commit real private keys.

# Required for solver signing (64 hex chars, with or without 0x)
SOLVER_PRIVATE_KEY=your_64_hex_char_solver_key_here

# Required for Tron native submit signer mapping (Shasta)
SOLVER_PRIVATE_KEY_TRON_SHASTA=your_64_hex_char_tron_shasta_solver_key_here

# Optional user key for local API probing scripts
USER_PRIVATE_KEY=your_64_hex_char_user_key_here

# Required for Redis-backed solver config
REDIS_URL=redis://localhost:6379

# Set after first successful bootstrap
# SOLVER_ID=tron-shasta-hyperevm-testnet

# Solver API base URL (must include /api/v1)
SOLVER_BASE_URL=http://127.0.0.1:3000/api/v1

# Shasta JSON-RPC endpoint (read compatibility path)
TRON_SHASTA_RPC_URL=https://api.shasta.trongrid.io/jsonrpc

# HyperEVM testnet RPC endpoint
HYPEREVM_TESTNET_RPC_URL=https://rpc.hyperliquid-testnet.xyz/evm

# Explicit tron chain split for delivery routing
TRON_CHAIN_IDS=2494104990

# Optional admin auth secret if auth_enabled=true
JWT_SECRET=
